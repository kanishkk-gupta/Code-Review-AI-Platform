# =============================================================================
# CodeGuardian AI — .gitignore
# =============================================================================

# ── Environment ───────────────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.installed.cfg
lib/
lib64/
parts/
sdist/
var/
wheels/
*.whl

# ── Virtual Environments ─────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
.conda/

# ── Testing ──────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.tox/
nosetests.xml
test-results/
*.test.log

# ── Type Checking ────────────────────────────────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/

# ── Linting ──────────────────────────────────────────────────────────────────
.ruff_cache/

# ── IDE / Editor ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Jupyter ──────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/
*.log.*

# ── FAISS Indexes (in-process, never persisted in git) ───────────────────────
*.faiss
*.index
faiss_indexes/

# ── Model Cache (sentence-transformers downloads) ────────────────────────────
.cache/
models/
model_cache/
sentence_transformers_cache/

# ── Report Output ────────────────────────────────────────────────────────────
reports/output/
*.pdf

# ── Uploaded Repos (temp extraction) ────────────────────────────────────────
/tmp/
uploads/
extracted/

# ── Docker ───────────────────────────────────────────────────────────────────
*.pid

# ── Node (if any tooling) ────────────────────────────────────────────────────
node_modules/
package-lock.json

# ── Secrets ──────────────────────────────────────────────────────────────────
*.pem
*.key
*.crt
secrets/
