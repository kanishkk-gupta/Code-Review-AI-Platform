# =============================================================================
# CodeGuardian AI — Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development                        # development | staging | production
APP_VERSION=1.0.0
LOG_LEVEL=INFO                             # DEBUG | INFO | WARNING | ERROR

# ── API Security ─────────────────────────────────────────────────────────────
API_KEY=your-secret-api-key-here           # X-API-Key header value
CORS_ORIGINS=["http://localhost:8501"]     # JSON list of allowed origins
MAX_UPLOAD_SIZE_MB=50                      # Max ZIP upload size

# ── LLM Provider (choose one) ────────────────────────────────────────────────
# Option A: OpenAI
OPENAI_API_KEY=sk-...
LLM_MODEL_NAME=gpt-4o-mini                # gpt-4o | gpt-4o-mini | gpt-3.5-turbo

# Option B: Ollama (local, no API key needed)
# OLLAMA_BASE_URL=http://localhost:11434
# LLM_MODEL_NAME=llama3

# LLM Behavior
LLM_TEMPERATURE=0.1                        # 0.0–1.0; keep low for deterministic output
LLM_MAX_RETRIES=3                          # Retry attempts on transient LLM errors
LLM_REQUEST_TIMEOUT=60                     # Seconds before LLM request times out

# ── Embedding Model ──────────────────────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu                       # cpu | cuda | mps

# ── Job Store ────────────────────────────────────────────────────────────────
JOB_TTL_SECONDS=86400                      # 24 hours; jobs evicted after this
REDIS_URL=                                 # Leave blank for in-memory store (dev)
                                           # redis://localhost:6379/0

# ── Chunker ──────────────────────────────────────────────────────────────────
DEFAULT_MAX_CHUNK_LINES=80                 # Default lines per CodeChunk
DEFAULT_SIMILARITY_TOP_K=3                # Default FAISS neighbors per finding

# ── API Server ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1                              # Uvicorn worker count (1 for dev)
API_BASE_URL=http://localhost:8000         # Used to build poll_url in responses

# ── Streamlit UI ──────────────────────────────────────────────────────────────
STREAMLIT_API_BASE_URL=http://localhost:8000
STREAMLIT_PORT=8501

# ── Report Generation ────────────────────────────────────────────────────────
REPORTS_OUTPUT_DIR=./reports/output        # Directory for generated PDF reports
